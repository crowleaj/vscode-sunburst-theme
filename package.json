      {
        "label": "Sunburst Light",
        "uiTheme": "vs",
        "path": "./themes/sunburst-light-color-theme.json"
      },
      {
        "label": "Blueburst Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/blueburst-dark-color-theme.json"
      }
