{
  "name": "sunburst",
  "displayName": "Sunburst",
  "description": "Sunburst theme for VS Code",
  "publisher": "crowleaj",
  "repository": {
    "type": "git",
    "url": "https://github.com/crowleaj/vscode-sunburst-theme"
  },
  "homepage": "https://github.com/crowleaj/vscode-sunburst-theme#readme",
  "bugs": {
    "url": "https://github.com/crowleaj/vscode-sunburst-theme/issues"
  },
  "license": "MIT",
  "keywords": [
    "sunburst",
    "blueburst",
    "theme",
    "dark",
    "light"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#2B1D0E",
    "theme": "dark"
  },
  "version": "1.3.0",
  "scripts": {
    "generate:themes": "node scripts/generate-themes.mjs"
  },
  "engines": {
    "vscode": "^1.97.0"
